BOT_TOKEN=123456:replace-me

# Set to true if you want docker compose and the VPS deploy workflow to start a
# local Telegram Bot API server side by side with the bot.
USE_LOCAL_TELEGRAM_BOT_API=false

# Required only when USE_LOCAL_TELEGRAM_BOT_API=true. Obtain these from
# https://my.telegram.org.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegraph account token. If empty, the bot will create a temporary account
# on startup and log the new token. Persisting your own token is recommended.
TELEGRAPH_ACCESS_TOKEN=
TELEGRAPH_SHORT_NAME=zip2telegraph
TELEGRAPH_AUTHOR_NAME=zip2telegraph-bot
TELEGRAPH_AUTHOR_URL=

TELEGRAPH_API_URL=https://api.telegra.ph

# For local Python runs, these control the app's own filesystem paths.
# In Docker Compose mode, they are overridden to fixed container paths:
# /app/data, /app/tmp, /app/public-images.
PUBLIC_IMAGE_DIR=./public-images
PUBLIC_IMAGE_BASE_URL=https://img.example.com/zip2telegraph

# Docker Compose host-side bind mount paths. These affect only the host paths,
# not the container-internal DATA_DIR/TMP_DIR/PUBLIC_IMAGE_DIR values above.
HOST_DATA_DIR=./data
HOST_TMP_DIR=./tmp
HOST_PUBLIC_IMAGE_DIR=./public-images
HOST_TELEGRAM_BOT_API_DATA_DIR=./telegram-bot-api-data

# Leave empty to use the public Telegram Bot API.
# When USE_LOCAL_TELEGRAM_BOT_API=true, docker compose overrides these values
# automatically to point at the local Bot API container.
# Note: the public Bot API currently allows bots to download files only up to
# 20 MB. Larger ZIP support requires a self-hosted local Bot API server.
TELEGRAM_API_BASE=
TELEGRAM_LOCAL_MODE=false

TIMEZONE=Asia/Tokyo
DATA_DIR=./data
TMP_DIR=./tmp
LOG_LEVEL=INFO

CHAT_RATE_LIMIT_WINDOW_SECONDS=300
CHAT_RATE_LIMIT_MAX_CALLS=1
USER_RATE_LIMIT_WINDOW_SECONDS=3600
USER_RATE_LIMIT_MAX_CALLS=3

ZIP_MAX_SIZE_BYTES=1073741824
IMAGE_MAX_SIZE_BYTES=10485760
EXTRACTED_MAX_TOTAL_BYTES=2147483648
TASK_TIMEOUT_SECONDS=1200
